generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ProcessedWebhookEvent {
  eventKey  String   @id @map("event_key")
  payoutId  String   @map("payout_id")
  status    Int
  subStatus Int      @map("sub_status")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("processed_webhook_events")
}

model PayoutNotification {
  id                        BigInt   @id @default(autoincrement())
  eventKey                  String?  @map("event_key")
  payoutId                  String   @map("payout_id")
  siteCode                  String?  @map("site_code")
  merchantReference         String?  @map("merchant_reference")
  customerMerchantReference String?  @map("customer_merchant_reference")
  status                    Int?
  subStatus                 Int?     @map("sub_status")
  hashValid                 Boolean  @map("hash_valid")
  duplicate                 Boolean
  reason                    String?
  rawPayload                Json     @map("raw_payload")
  createdAt                 DateTime @default(now()) @map("created_at")

  @@index([payoutId], map: "idx_payout_notifications_payout_id")
  @@map("payout_notifications")
}

model Payout {
  payoutId                  String   @id @map("payout_id")
  siteCode                  String?  @map("site_code")
  merchantReference         String?  @map("merchant_reference")
  customerMerchantReference String?  @map("customer_merchant_reference")
  lastStatus                Int?     @map("last_status")
  lastSubStatus             Int?     @map("last_sub_status")
  lastNotificationAt        DateTime @default(now()) @map("last_notification_at")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  @@map("payouts")
}
